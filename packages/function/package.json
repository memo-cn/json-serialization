{
    "name": "@json-serialization/function",
    "private": false,
    "version": "0.0.4",
    "description": "@json-serialization/function provides a mechanism for function serialization and deserialization, which can implement cross-context function calls without using eval. @json-serialization/function 提供了一种函数序列化和反序列化的机制，能够在不使用 eval 的情况下实现函数的跨上下文调用。",
    "keywords": [
        "function",
        "serialization"
    ],
    "homepage": "https://github.com/memo-cn/json-serialization/tree/main/packages/function#readme",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "rimraf ./dist/* && rollup -c --configPlugin rollup-plugin-typescript2"
    },
    "devDependencies": {
        "@babel/core": "^7.24.6",
        "@babel/preset-env": "^7.24.6",
        "@rollup/plugin-babel": "^6.0.4",
        "@rollup/plugin-commonjs": "^25.0.8",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.3",
        "@rollup/plugin-replace": "^5.0.5",
        "@rollup/plugin-terser": "^0.4.4",
        "@types/node": "^20.14.1",
        "json-serialization": "^0.0.4",
        "rimraf": "^5.0.7",
        "rollup": "^4.18.0",
        "rollup-plugin-dts": "^6.1.1",
        "rollup-plugin-typescript2": "^0.36.0",
        "tslib": "^2.6.2",
        "typescript": "^5.4.5",
        "vite": "^5.2.12"
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "LICENSE",
        "package.json",
        "README.md",
        "README.zh-CN.md"
    ],
    "author": {
        "name": "memo",
        "email": "i@memo.cool"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:memo-cn/json-serialization.git"
    },
    "bugs": {
        "email": "i@memo.cool",
        "url": "https://github.com/memo-cn/json-serialization/issues"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "license": "MIT"
}
