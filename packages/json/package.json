{
    "name": "json-serialization",
    "private": false,
    "version": "0.0.1",
    "description": "json-serialization is an extensible asynchronous JSON serialization library. json-serialization 是一个可扩展的异步 JSON 序列化库。",
    "keywords": [
        "extensible",
        "async",
        "json",
        "serialization"
    ],
    "homepage": "https://github.com/memo-cn/json-serialization/tree/main/packages/json#readme",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "require": "./dist/index.cjs",
            "import": "./dist/index.mjs",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build"
    },
    "devDependencies": {
        "@types/node": "^20.12.8",
        "typescript": "^5.4.5",
        "vite": "^5.2.10",
        "vite-plugin-dts": "^3.9.0"
    },
    "files": [
        "dist",
        "CHANGELOG.md",
        "LICENSE",
        "package.json",
        "README.md",
        "README.zh-CN.md"
    ],
    "author": {
        "name": "memo",
        "email": "i@memo.cool"
    },
    "repository": {
        "type": "git",
        "url": "git@github.com:memo-cn/json-serialization.git"
    },
    "bugs": {
        "email": "i@memo.cool",
        "url": "https://github.com/memo-cn/json-serialization/issues"
    },
    "publishConfig": {
        "access": "public",
        "registry": "https://registry.npmjs.org"
    },
    "license": "MIT"
}
